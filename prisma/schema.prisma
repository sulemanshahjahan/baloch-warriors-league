generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum GameCategory {
  FOOTBALL
  EFOOTBALL
  PUBG
  SNOOKER
  CHECKERS
}

enum TournamentFormat {
  LEAGUE
  KNOCKOUT
  GROUP_KNOCKOUT
}

enum ParticipantType {
  TEAM
  INDIVIDUAL
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ScoreReportStatus {
  PENDING
  CONFIRMED
  DISPUTED
  AUTO_CONFIRMED
  CANCELLED
}

enum MatchEventType {
  // Football & eFootball
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISS
  CLEAN_SHEET
  MOTM
  // PUBG
  KILL
  // Snooker / Checkers / Generic
  FRAME_WIN
  MVP
  CUSTOM
}

enum AwardType {
  GOLDEN_BOOT
  TOP_ASSISTS
  BEST_PLAYER
  BEST_GOALKEEPER
  FAIR_PLAY
  TOURNAMENT_MVP
  TOURNAMENT_WINNER
  CUSTOM
}

enum ParticipantResult {
  WIN
  LOSS
  DRAW
  DNF
}

// ─────────────────────────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────────────────────────

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      AdminRole @default(EDITOR)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  activityLogs ActivityLog[]

  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────
// SEASON
// ─────────────────────────────────────────────────────────────

model Season {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())

  tournaments Tournament[]

  @@map("seasons")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT
// ─────────────────────────────────────────────────────────────

model Tournament {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String?          @db.Text
  bannerUrl       String?
  logoUrl         String?
  gameCategory    GameCategory
  format          TournamentFormat
  participantType ParticipantType  @default(TEAM)
  status          TournamentStatus @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  seasonId        String?
  maxParticipants Int?
  rules           String?          @db.Text
  prizeInfo       String?
  isFeatured      Boolean          @default(false)
  // eFootball-specific
  eFootballMode   String? // "1v1" or "2v2" (only for EFOOTBALL)
  eFootballType   String? // "AUTHENTIC" or "DREAM" (only for EFOOTBALL)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  season       Season?            @relation(fields: [seasonId], references: [id])
  teams        TournamentTeam[]
  players      TournamentPlayer[]
  groups       TournamentGroup[]
  matches      Match[]
  standings    Standing[]
  awards       Award[]
  whatsappLogs WhatsAppLog[]

  // ── Scheduling system ──
  schedulingSettings      TournamentSchedulingSettings?
  stageOverrides          StageSchedulingOverride[]
  substituteRegistrations SubstituteRegistration[]

  @@index([gameCategory])
  @@index([status])
  @@map("tournaments")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT GROUP
// ─────────────────────────────────────────────────────────────

model TournamentGroup {
  id           String @id @default(cuid())
  tournamentId String
  name         String
  orderIndex   Int    @default(0)

  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams      TournamentTeam[]
  players    TournamentPlayer[]
  matches    Match[]
  standings  Standing[]

  @@unique([tournamentId, name])
  @@map("tournament_groups")
}

// ─────────────────────────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────────────────────────

model Team {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  shortName    String?
  logoUrl      String?
  primaryColor String?
  captainId    String?
  isActive     Boolean  @default(true)
  // True when this "team" is actually a 2v2 eFootball duo (exactly 2 players).
  // Duo teams are hidden from the global/public team directories.
  isDuo        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  captain      Player?            @relation("TeamCaptain", fields: [captainId], references: [id])
  players      TeamPlayer[]
  tournaments  TournamentTeam[]
  homeMatches  Match[]            @relation("HomeTeam")
  awayMatches  Match[]            @relation("AwayTeam")
  matchEvents  MatchEvent[]
  participants MatchParticipant[]
  awards       Award[]
  standings    Standing[]

  // ── Scheduling system ──
  matchConfirmations      MatchParticipantConfirmation[]
  substituteRegistrations SubstituteRegistration[]

  @@index([isActive])
  @@map("teams")
}

// ─────────────────────────────────────────────────────────────
// PLAYER
// ─────────────────────────────────────────────────────────────

model Player {
  id                 String    @id @default(cuid())
  name               String
  nickname           String?
  slug               String    @unique
  photoUrl           String?
  dateOfBirth        DateTime?
  nationality        String?
  phone              String? // WhatsApp number with country code e.g. +923001234567
  email              String?   @unique // login email (player accounts)
  passwordHash       String? // bcrypt hash for email+password login
  position           String?
  skillLevel         Int?      @default(50) // 0-99 rating for seeding
  eloRating          Int       @default(100)
  cardRank           Int       @default(70) // FIFA-style card rank, 50-99
  // ── BWL Legacy / economy (status only — never affects ELO/cardRank/matchmaking) ──
  coins              Int       @default(0)
  legacyXp           Int       @default(0)
  legacyLevel        Int       @default(1)
  legacyTier         String    @default("Rookie")
  legacyTokens       Int       @default(0)
  bio                String?   @db.Text
  // ── Presence (admin "Active Users" panel; approx location from IP headers) ──
  lastSeenAt         DateTime?
  lastCountry        String?
  lastCity           String?
  lastPath           String?
  pageViews          Int       @default(0)
  isActive           Boolean   @default(true)
  registrationStatus String    @default("APPROVED") // PENDING, APPROVED, REJECTED
  suspendedUntil     DateTime?
  suspensionReason   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  teams           TeamPlayer[]
  tournaments     TournamentPlayer[]
  matchEvents     MatchEvent[]
  participants    MatchParticipant[]
  captainOf       Team[]                   @relation("TeamCaptain")
  awards          Award[]
  manOfTheMatches Match[]                  @relation("MatchMOTM")
  homeMatches     Match[]                  @relation("HomePlayer")
  awayMatches     Match[]                  @relation("AwayPlayer")
  standings       Standing[]
  eloHistory      EloHistory[]
  eloAsOpponent   EloHistory[]             @relation("EloOpponent")
  availabilities  MatchAvailability[]
  playerOfWeeks   PlayerOfWeek[]
  whatsappLogs    WhatsAppLog[]
  rankChanges     RankChange[]
  legacyTxns      LegacyXpTransaction[]
  seasonProgress  PlayerSeasonProgress[]
  seasonTxns      SeasonXpTransaction[]
  contracts       PlayerContract[]
  respect         PlayerRespect?
  respectTxns     RespectTransaction[]
  moments         PlayerMoment[]
  inventory       PlayerInventoryItem[]
  equipped        PlayerEquippedCosmetics?
  predictions     MatchPrediction[]
  raffleEntries   RaffleEntry[]
  visitorSessions VisitorSession[]

  // ── Scheduling system ──
  availabilityPeriods     PlayerAvailabilityPeriod[]
  availabilityBlocks      AvailabilityBlock[]
  availabilityTemplates   AvailabilityTemplate[]
  matchConfirmations      MatchParticipantConfirmation[]
  substituteRegistrations SubstituteRegistration[]
  matchCheckIns           MatchCheckIn[]

  @@index([isActive])
  @@map("players")
}

// ─────────────────────────────────────────────────────────────
// BWL LEGACY — XP / COIN LEDGER (idempotent reward log)
// ─────────────────────────────────────────────────────────────

model LegacyXpTransaction {
  id        String   @id @default(cuid())
  playerId  String
  xp        Int      @default(0)
  coins     Int      @default(0)
  source    String // MATCH_PLAYED, MATCH_WIN, CLEAN_SHEET, MOTM, …
  sourceId  String? // e.g. matchId — makes the reward idempotent per event
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // One reward per (player, source, event) — safe to re-run match completion.
  @@unique([playerId, source, sourceId])
  @@index([playerId])
  @@index([playerId, createdAt])
  @@map("legacy_xp_transactions")
}

// ─────────────────────────────────────────────────────────────
// SEASON PROGRESS (resets each season — uses existing Season.id)
// ─────────────────────────────────────────────────────────────

model PlayerSeasonProgress {
  id        String   @id @default(cuid())
  playerId  String
  seasonId  String
  seasonXp  Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
  @@index([seasonId])
  @@map("player_season_progress")
}

model SeasonXpTransaction {
  id        String   @id @default(cuid())
  playerId  String
  seasonId  String
  xp        Int      @default(0)
  source    String
  sourceId  String?
  reason    String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId, source, sourceId])
  @@index([playerId, seasonId])
  @@map("season_xp_transactions")
}

// ─────────────────────────────────────────────────────────────
// MATCH CONTRACTS (daily / weekly challenges)
// ─────────────────────────────────────────────────────────────

model PlayerContract {
  id          String    @id @default(cuid())
  playerId    String
  templateKey String
  period      String // "2026-06-30" (daily) or "2026-W26" (weekly)
  type        String // DAILY, WEEKLY
  title       String
  condition   String // PLAY_MATCHES, WIN_MATCHES, CLEAN_SHEETS
  target      Int
  progress    Int       @default(0)
  rewardXp    Int       @default(0)
  rewardCoins Int       @default(0)
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, templateKey, period])
  @@index([playerId, status])
  @@map("player_contracts")
}

// ─────────────────────────────────────────────────────────────
// RESPECT SCORE (fair-play reputation, 0-100)
// ─────────────────────────────────────────────────────────────

model PlayerRespect {
  id        String   @id @default(cuid())
  playerId  String   @unique
  score     Int      @default(80)
  label     String   @default("Good Standing")
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_respect")
}

model RespectTransaction {
  id        String   @id @default(cuid())
  playerId  String
  amount    Int
  source    String
  sourceId  String?
  reason    String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, source, sourceId])
  @@index([playerId])
  @@map("respect_transactions")
}

// ─────────────────────────────────────────────────────────────
// BWL MOMENTS (permanent career memories)
// ─────────────────────────────────────────────────────────────

model PlayerMoment {
  id           String   @id @default(cuid())
  playerId     String
  type         String // FIRST_WIN, FIRST_CLEAN_SHEET, REACHED_99, HOT_STREAK_5, TOURNAMENT_WIN …
  title        String
  description  String
  icon         String?
  rarity       String   @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  matchId      String?
  tournamentId String?
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Most moments are once-per-player (FIRST_*, REACHED_99). Repeatable ones
  // include a discriminator in `type` (e.g. TOURNAMENT_WIN:<tournamentId>).
  @@unique([playerId, type])
  @@index([playerId])
  @@map("player_moments")
}

// ─────────────────────────────────────────────────────────────
// COSMETICS — owned inventory + equipped slots
// ─────────────────────────────────────────────────────────────

model PlayerInventoryItem {
  id         String   @id @default(cuid())
  playerId   String
  itemType   String // PROFILE_FRAME, PROFILE_BANNER, NAME_COLOR, TITLE, CARD_BG
  itemKey    String
  source     String // STORE, LEGACY_LEVEL, SEASON, ADMIN
  acquiredAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, itemType, itemKey])
  @@index([playerId])
  @@map("player_inventory_items")
}

model PlayerEquippedCosmetics {
  id            String   @id @default(cuid())
  playerId      String   @unique
  profileFrame  String?
  profileBanner String?
  nameColor     String?
  cardBg        String?
  updatedAt     DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_equipped_cosmetics")
}

// ─────────────────────────────────────────────────────────────
// PREDICTIONS (predict upcoming match outcomes for coins/XP)
// ─────────────────────────────────────────────────────────────

model MatchPrediction {
  id        String    @id @default(cuid())
  playerId  String
  matchId   String
  pick      String // HOME, AWAY, DRAW
  settled   Boolean   @default(false)
  correct   Boolean?
  createdAt DateTime  @default(now())
  settledAt DateTime?

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId])
  @@index([matchId])
  @@index([playerId])
  @@map("match_predictions")
}

// ─────────────────────────────────────────────────────────────
// RAFFLES (spend coins on tickets for real prizes)
// ─────────────────────────────────────────────────────────────

model Raffle {
  id             String    @id @default(cuid())
  name           String
  description    String?
  prize          String
  costPerTicket  Int       @default(100)
  isActive       Boolean   @default(true)
  drawsAt        DateTime?
  winnerPlayerId String?
  createdAt      DateTime  @default(now())

  entries RaffleEntry[]

  @@map("raffles")
}

model RaffleEntry {
  id        String   @id @default(cuid())
  raffleId  String
  playerId  String
  tickets   Int      @default(0)
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([raffleId, playerId])
  @@index([raffleId])
  @@map("raffle_entries")
}

// ─────────────────────────────────────────────────────────────
// PLAYER OTP LOGIN (one-time codes sent to the profile phone)
// ─────────────────────────────────────────────────────────────

model PlayerOtp {
  id        String   @id @default(cuid())
  email     String   @unique // login email (lowercased)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("player_otps")
}

// One-time code for the mobile-app OAuth bridge: the external browser writes it
// after a successful Google login; the app's webview polls + redeems it so the
// session cookie lands in the webview's cookie jar.
model PlayerAuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  playerId  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("player_auth_codes")
}

// ─────────────────────────────────────────────────────────────
// ADMIN REWARD AUDIT LOG (manual XP/coin/respect adjustments)
// ─────────────────────────────────────────────────────────────

model AdminRewardAuditLog {
  id             String   @id @default(cuid())
  adminId        String
  targetPlayerId String
  action         String
  beforeJson     Json?
  afterJson      Json?
  reason         String
  createdAt      DateTime @default(now())

  @@index([targetPlayerId])
  @@map("admin_reward_audit_logs")
}

// ─────────────────────────────────────────────────────────────
// CARD RANK CHANGE HISTORY
// ─────────────────────────────────────────────────────────────

model RankChange {
  id          String   @id @default(cuid())
  playerId    String
  oldRank     Int
  newRank     Int
  reason      String   @db.Text // Human-readable summary
  reasonStats Json? // Structured stats snapshot used for the calculation
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
  @@map("rank_changes")
}

// ─────────────────────────────────────────────────────────────
// TEAM ↔ PLAYER (roster + transfer history)
// ─────────────────────────────────────────────────────────────

model TeamPlayer {
  id           String    @id @default(cuid())
  teamId       String
  playerId     String
  jerseyNumber Int?
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?
  isActive     Boolean   @default(true)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId, joinedAt])
  @@index([teamId])
  @@index([playerId])
  @@map("team_players")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT TEAMS (enrollment)
// ─────────────────────────────────────────────────────────────

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  groupId      String?
  seedNumber   Int?
  registeredAt DateTime @default(now())

  tournament Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team             @relation(fields: [teamId], references: [id])
  group      TournamentGroup? @relation(fields: [groupId], references: [id])

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@map("tournament_teams")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT PLAYERS (individual enrollment)
// ─────────────────────────────────────────────────────────────

model TournamentPlayer {
  id           String   @id @default(cuid())
  tournamentId String
  playerId     String
  teamId       String?
  groupId      String?
  registeredAt DateTime @default(now())

  tournament Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player           @relation(fields: [playerId], references: [id])
  group      TournamentGroup? @relation(fields: [groupId], references: [id])

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([groupId])
  @@map("tournament_players")
}

// ─────────────────────────────────────────────────────────────
// VENUE
// ─────────────────────────────────────────────────────────────

model Venue {
  id      String  @id @default(cuid())
  name    String
  address String?
  city    String?

  matches Match[]

  @@map("venues")
}

// ─────────────────────────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────────────────────────

model Match {
  id           String  @id @default(cuid())
  tournamentId String
  groupId      String?
  venueId      String?

  // Round info
  round       String?
  roundNumber Int?
  matchNumber Int?

  // Team vs team
  homeTeamId String?
  awayTeamId String?

  // Player vs player (e.g. eFootball 1v1)
  homePlayerId String?
  awayPlayerId String?

  // Leg 1 scores (or single match score)
  homeScore     Int?
  awayScore     Int?
  homeScorePens Int?
  awayScorePens Int?

  // Leg 2 scores (knockout 2-legged ties)
  leg2HomeScore Int?
  leg2AwayScore Int?

  // Leg 3 / Decider (if aggregate tied after 2 legs)
  leg3HomeScore Int?
  leg3AwayScore Int?
  leg3HomePens  Int?
  leg3AwayPens  Int?

  // In-game clubs (eFootball)
  homeClub String?
  awayClub String?

  // Formation & tactics (eFootball)
  homeFormation String?
  awayFormation String?

  // Derby / rivalry
  isDerby   Boolean @default(false)
  rivalNote String?

  // Man of the match
  motmPlayerId String?

  // Knockout bracket progression
  nextMatchId       String?
  nextMatchPosition String? // "home" or "away"

  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  highlights  String?     @db.Text

  // Deadline & reminder system
  deadline      DateTime?
  remindersSent Json      @default("[]")
  isOverdue     Boolean   @default(false)

  // Room ID for online matches (eFootball, PUBG)
  roomId       String?
  roomPassword String?

  // Score self-reporting magic link tokens
  homeToken String? @unique
  awayToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament      Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group           TournamentGroup?    @relation(fields: [groupId], references: [id])
  venue           Venue?              @relation(fields: [venueId], references: [id])
  homeTeam        Team?               @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team?               @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homePlayer      Player?             @relation("HomePlayer", fields: [homePlayerId], references: [id])
  awayPlayer      Player?             @relation("AwayPlayer", fields: [awayPlayerId], references: [id])
  motmPlayer      Player?             @relation("MatchMOTM", fields: [motmPlayerId], references: [id])
  events          MatchEvent[]
  participants    MatchParticipant[]
  nextMatch       Match?              @relation("KnockoutProgression", fields: [nextMatchId], references: [id])
  previousMatches Match[]             @relation("KnockoutProgression")
  eloHistory      EloHistory[]
  scoreReports    ScoreReport[]
  availabilities  MatchAvailability[]
  whatsappLogs    WhatsAppLog[]
  predictions     MatchPrediction[]

  // ── Scheduling system ──
  schedule              MatchSchedule?
  rescheduleRequests    RescheduleRequest[]
  substituteActivations SubstituteActivation[]
  checkIns              MatchCheckIn[]

  @@index([tournamentId])
  @@index([status])
  @@index([status, deadline])
  @@index([homePlayerId])
  @@index([awayPlayerId])
  @@map("matches")
}

// ─────────────────────────────────────────────────────────────
// ELO HISTORY
// ─────────────────────────────────────────────────────────────

model EloHistory {
  id                   String   @id @default(cuid())
  playerId             String
  matchId              String
  ratingBefore         Int
  ratingAfter          Int
  change               Int
  opponentId           String
  opponentRatingBefore Int
  result               String // WIN, LOSS, DRAW
  kFactor              Int
  createdAt            DateTime @default(now())

  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  opponent Player @relation("EloOpponent", fields: [opponentId], references: [id])

  @@index([playerId])
  @@index([matchId])
  @@index([playerId, createdAt])
  @@map("elo_history")
}

// ─────────────────────────────────────────────────────────────
// MATCH PARTICIPANT (multi-team/PUBG battle royale)
// ─────────────────────────────────────────────────────────────

model MatchParticipant {
  id        String             @id @default(cuid())
  matchId   String
  teamId    String?
  playerId  String?
  placement Int?
  score     Float?
  result    ParticipantResult?
  notes     String?

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])

  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@map("match_participants")
}

// ─────────────────────────────────────────────────────────────
// MATCH EVENT (atomic stat record — source of truth)
// ─────────────────────────────────────────────────────────────

model MatchEvent {
  id          String         @id @default(cuid())
  matchId     String
  playerId    String?
  teamId      String?
  type        MatchEventType
  minute      Int?
  value       Float?
  description String?
  createdAt   DateTime       @default(now())

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id])
  team   Team?   @relation(fields: [teamId], references: [id])

  @@index([matchId])
  @@index([playerId])
  @@index([type])
  @@map("match_events")
}

// ─────────────────────────────────────────────────────────────
// STANDING (points table — recomputed after every result)
// ─────────────────────────────────────────────────────────────

model Standing {
  id           String  @id @default(cuid())
  tournamentId String
  groupId      String?
  teamId       String?
  playerId     String?

  played Int @default(0)
  won    Int @default(0)
  drawn  Int @default(0)
  lost   Int @default(0)
  points Int @default(0)

  // Football / eFootball
  goalsFor     Int @default(0)
  goalsAgainst Int @default(0)
  goalDiff     Int @default(0)
  cleanSheets  Int @default(0)

  // Generic (PUBG score, snooker frames, etc.)
  totalScore Float @default(0)

  updatedAt DateTime @updatedAt

  tournament Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group      TournamentGroup? @relation(fields: [groupId], references: [id])
  team       Team?            @relation(fields: [teamId], references: [id])
  player     Player?          @relation(fields: [playerId], references: [id])

  @@index([tournamentId])
  @@index([tournamentId, playerId])
  @@index([tournamentId, teamId])
  @@map("standings")
}

// ─────────────────────────────────────────────────────────────
// AWARD
// ─────────────────────────────────────────────────────────────

model Award {
  id           String    @id @default(cuid())
  tournamentId String
  type         AwardType
  customName   String?
  playerId     String?
  teamId       String?
  description  String?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player?    @relation(fields: [playerId], references: [id])
  team       Team?      @relation(fields: [teamId], references: [id])

  @@index([tournamentId])
  @@index([tournamentId, type])
  @@map("awards")
}

// ─────────────────────────────────────────────────────────────
// NEWS POST
// ─────────────────────────────────────────────────────────────

model NewsPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  coverUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("news_posts")
}

// ─────────────────────────────────────────────────────────────
// VISITOR PRESENCE (admin "Active Users" — every browser, not just members)
// ─────────────────────────────────────────────────────────────

model VisitorSession {
  id          String   @id // anonymous visitor cookie id
  playerId    String? // set once/if the visitor logs in
  country     String?
  city        String?
  lastPath    String?
  pageViews   Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([lastSeenAt])
  @@map("visitor_sessions")
}

// ─────────────────────────────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────
// PUSH SUBSCRIPTIONS (Web Push API)
// ─────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model FcmToken {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())

  @@map("fcm_tokens")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION LOG (central record of all sent notifications)
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  url       String?
  tag       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// APP SETTINGS (single-row global config)
// ─────────────────────────────────────────────────────────────

model AppSettings {
  id String @id @default("global")

  // Global kill switch
  testMode Boolean @default(false)

  // Push notification toggles (Web Push + FCM)
  pushMatchReminders    Boolean @default(true)
  pushScoreSubmissions  Boolean @default(true)
  pushMatchResults      Boolean @default(true)
  pushTournamentUpdates Boolean @default(true)
  pushRoomId            Boolean @default(true)
  pushAdminAlerts       Boolean @default(true)

  // WhatsApp notification toggles
  waMatchReminders    Boolean @default(true)
  waScoreSubmissions  Boolean @default(true)
  waMatchResults      Boolean @default(true)
  waTournamentUpdates Boolean @default(true)
  waRoomId            Boolean @default(true)
  waAdminAlerts       Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────────────────────────────────
// MATCH AVAILABILITY (player readiness tracking)
// ─────────────────────────────────────────────────────────────

model MatchAvailability {
  id            String    @id @default(cuid())
  matchId       String
  playerId      String
  side          String // "home" or "away"
  isAvailable   Boolean   @default(true)
  preferredTime DateTime?
  markedAt      DateTime  @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, side])
  @@index([matchId])
  @@map("match_availabilities")
}

// ─────────────────────────────────────────────────────────────
// SCORE SELF-REPORTING
// ─────────────────────────────────────────────────────────────

model ScoreReport {
  id            String            @id @default(cuid())
  matchId       String
  submittedBy   String // "home" or "away"
  homeScore     Int
  awayScore     Int
  status        ScoreReportStatus @default(PENDING)
  submittedAt   DateTime          @default(now())
  respondedAt   DateTime?
  autoConfirmAt DateTime
  disputeReason String?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([status, autoConfirmAt])
  @@map("score_reports")
}

// ─────────────────────────────────────────────────────────────
// PLAYER OF THE WEEK (auto-generated weekly)
// ─────────────────────────────────────────────────────────────

model PlayerOfWeek {
  id            String   @id @default(cuid())
  playerId      String
  weekStart     DateTime
  weekEnd       DateTime
  goals         Int
  wins          Int
  matchesPlayed Int
  eloGained     Int
  score         Int // composite score used to pick
  createdAt     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@unique([weekStart])
  @@index([createdAt])
  @@map("player_of_week")
}

// ─────────────────────────────────────────────────────────────
// WHATSAPP MESSAGE LOG (audit + dedup)
// ─────────────────────────────────────────────────────────────

model WhatsAppLog {
  id           String  @id @default(cuid())
  matchId      String?
  playerId     String?
  tournamentId String?

  phone        String // cleaned phone number we sent to
  templateName String // e.g. match_reminder, match_schedule, fixture_summary
  category     String // REMINDER | SCHEDULE | FIXTURE | OPPONENT_READY | OTHER
  parameters   Json // template parameters (for audit)

  status String // SENT | FAILED | SKIPPED
  error  String?

  // Idempotency key — if a SENT row with this key exists, skip re-sending
  dedupKey String @unique

  createdAt DateTime @default(now())

  match      Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  player     Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([playerId])
  @@index([tournamentId])
  @@index([category, createdAt])
  @@index([createdAt])
  @@map("whatsapp_logs")
}

// ═════════════════════════════════════════════════════════════
// SCHEDULING SYSTEM
// Monthly availability + match-level confirmation, overlap engine,
// rescheduling, substitutes, check-in, audit. All additive — existing
// fixtures keep working with no scheduling record.
// ═════════════════════════════════════════════════════════════

enum AvailabilityPeriodStatus {
  DRAFT
  SUBMITTED
  LOCKED
  REOPENED
}

// Distinct statuses — the engine weights these differently (see scheduling engine).
enum AvailabilityStatus {
  CONFIRMED // confidently available
  LIKELY // expects to be available, not fully confirmed
  UNAVAILABLE // cannot play
  SHIFT_UNCONFIRMED // work shift not known yet
  IF_NEEDED // prefers not to, but can adjust
  NO_RESPONSE // not submitted
}

enum DutyType {
  DAY_SHIFT
  NIGHT_SHIFT
  OFF_DUTY
  ROTATING
  UNKNOWN
  CUSTOM
}

enum AvailabilityPrivacy {
  PRIVATE // player + admin only
  TEAM_CAPTAIN // + captain
  TEAM // + teammates
  ENGINE_ONLY // used for overlap math, notes hidden
}

enum AvailabilitySource {
  MANUAL
  TEMPLATE
  COPIED
  ADMIN
}

enum SchedulingAvailabilityMode {
  MONTHLY
  WEEKLY
  TOURNAMENT_WIDE
  ROUND_SPECIFIC
  ADMIN_MANAGED
  HYBRID // monthly plan + per-match confirmation (BWL default)
}

enum SchedulingMode {
  AUTOMATIC // engine picks highest-scoring slot
  ADMIN_ASSISTED // engine suggests, admin selects
  PLAYER_CHOICE // engine generates, players/captains pick
  MANUAL // admin sets exact time
  WINDOW // play anytime inside a window
  OFFICIAL // fixed official time (finals/streams)
}

enum MinRequirementMode {
  HARD
  SOFT
  DISABLED
}

// Match scheduling state machine — transitions validated in the service layer.
enum MatchSchedulingStatus {
  FIXTURE_CREATED
  AWAITING_AVAILABILITY
  AVAILABILITY_INCOMPLETE
  CALCULATING_OVERLAP
  NO_COMMON_TIME
  PROPOSED
  AWAITING_SELECTION
  AWAITING_CONFIRMATION
  PARTIALLY_CONFIRMED
  FULLY_CONFIRMED
  SCHEDULED
  RESCHEDULE_REQUESTED
  RESCHEDULE_REVIEW
  RESCHEDULED
  SUBSTITUTE_REQUESTED
  SUBSTITUTE_PENDING
  SUBSTITUTE_APPROVED
  CHECK_IN_OPEN
  PLAYER_LATE
  NO_SHOW_REVIEW
  WALKOVER_PROPOSED
  ADMIN_DECISION
  COMPLETED
  CANCELLED
}

enum SlotEligibility {
  ELIGIBLE
  PARTIAL // some participants only likely / if-needed
  REQUIRES_SUBSTITUTE
  INELIGIBLE
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
  TENTATIVE
  NO_RESPONSE
  SUBSTITUTE
}

enum RescheduleReason {
  DUTY_SHIFT_CHANGED
  WORK_EMERGENCY
  MEDICAL_FAMILY
  TECHNICAL
  TRAVEL
  OPPONENT_REQUEST
  OTHER
}

enum RescheduleStatus {
  PENDING
  OPPONENT_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  COUNTERED
}

enum SubstituteRegStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum SubstituteActivationStatus {
  REQUESTED
  PENDING
  ACCEPTED
  DECLINED
  APPROVED
  REJECTED
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
  LATE
  EXCUSED
  NO_SHOW
  SUBSTITUTE_CHECKED_IN
}

enum CheckInSource {
  PLAYER
  CAPTAIN
  ADMIN
  AUTO
}

enum SchedulingActorType {
  ADMIN
  PLAYER
  SYSTEM
}

enum StageType {
  GROUP
  LEAGUE_ROUND
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
  THIRD_PLACE
  CUSTOM
}

// ─── MONTHLY AVAILABILITY PERIOD (one per player per month) ────

model PlayerAvailabilityPeriod {
  id            String                   @id @default(cuid())
  playerId      String
  month         Int // 1-12
  year          Int
  timezone      String                   @default("Asia/Karachi")
  status        AvailabilityPeriodStatus @default(DRAFT)
  submittedAt   DateTime?
  lockedAt      DateTime?
  submittedById String? // admin id when submitted/locked on player's behalf
  adminNotes    String?                  @db.Text
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  player Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  blocks AvailabilityBlock[]

  @@unique([playerId, month, year])
  @@index([playerId])
  @@index([year, month])
  @@index([status])
  @@map("player_availability_periods")
}

// ─── AVAILABILITY BLOCK (a time range on a specific date) ──────

model AvailabilityBlock {
  id            String              @id @default(cuid())
  periodId      String
  playerId      String
  date          DateTime            @db.Date // calendar day (in period timezone)
  startDateTime DateTime? // UTC instant; null when all-day
  endDateTime   DateTime? // UTC instant; may be next day if overnight
  status        AvailabilityStatus  @default(CONFIRMED)
  dutyType      DutyType?
  confidence    Int? // 0-100 optional confidence override
  isAllDay      Boolean             @default(false)
  isOvernight   Boolean             @default(false) // end crosses midnight
  note          String?
  privacy       AvailabilityPrivacy @default(PRIVATE)
  source        AvailabilitySource  @default(MANUAL)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  period PlayerAvailabilityPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  player Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, date])
  @@index([periodId])
  @@index([date])
  @@map("availability_blocks")
}

// ─── REUSABLE AVAILABILITY TEMPLATES ──────────────────────────

model AvailabilityTemplate {
  id          String   @id @default(cuid())
  playerId    String
  name        String
  description String?
  // JSON rules: { weekdays: { "1": [{start,end,status,duty}], ... }, allDay?, ... }
  rules       Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("availability_templates")
}

// ─── PER-TOURNAMENT SCHEDULING SETTINGS ───────────────────────

model TournamentSchedulingSettings {
  id           String @id @default(cuid())
  tournamentId String @unique

  enabled  Boolean @default(false)
  timezone String  @default("Asia/Karachi")

  availabilityMode SchedulingAvailabilityMode @default(HYBRID)
  schedulingMode   SchedulingMode             @default(ADMIN_ASSISTED)

  matchDurationMinutes   Int @default(60)
  preMatchBufferMinutes  Int @default(10)
  postMatchBufferMinutes Int @default(10)

  confirmationWindowHours Int @default(24)
  rescheduleCutoffHours   Int @default(6)
  maxReschedules          Int @default(1)
  gracePeriodMinutes      Int @default(10)

  // Minimum availability requirements
  minRequirementMode    MinRequirementMode @default(SOFT)
  minimumAvailableSlots Int?
  minimumAvailableDays  Int?
  minimumSlotDuration   Int? // minutes

  substitutesEnabled          Boolean @default(false)
  captainConfirmationEnabled  Boolean @default(false)
  earlyPlayEnabled            Boolean @default(true)
  autoWalkoverEnabled         Boolean @default(false)
  opponentAvailabilityVisible Boolean @default(true)

  availabilityOpensAt  DateTime?
  availabilityDeadline DateTime?

  // Flexible config blobs
  weights              Json? // availability status → score weight overrides
  visibilitySettings   Json?
  notificationSettings Json?
  reminderSettings     Json?
  noShowRules          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_scheduling_settings")
}

// ─── STAGE-SPECIFIC OVERRIDES (group / R16 / QF / SF / final) ──

model StageSchedulingOverride {
  id               String    @id @default(cuid())
  tournamentId     String
  stageType        StageType
  roundNumber      Int? // optional narrower scope
  // Partial settings blob merged over the tournament settings for this stage.
  settingsOverride Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, stageType, roundNumber])
  @@index([tournamentId])
  @@map("stage_scheduling_overrides")
}

// ─── MATCH SCHEDULE (one per Match that opts into scheduling) ──

model MatchSchedule {
  id      String @id @default(cuid())
  matchId String @unique

  schedulingStatus MatchSchedulingStatus @default(FIXTURE_CREATED)
  schedulingMode   SchedulingMode        @default(ADMIN_ASSISTED)
  timezone         String                @default("Asia/Karachi")

  windowStart          DateTime?
  windowEnd            DateTime?
  confirmationDeadline DateTime?
  rescheduleDeadline   DateTime?

  primaryStart DateTime?
  primaryEnd   DateTime?
  backupStart  DateTime?
  backupEnd    DateTime?

  checkInOpensAt DateTime?
  kickoffAt      DateTime?
  gracePeriodEnd DateTime?
  resultDeadline DateTime?

  selectedSlotId       String?
  autoGenerated        Boolean @default(false)
  adminOverride        Boolean @default(false)
  overrideReason       String?
  schedulingConfidence Float?
  rescheduleCount      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match         Match                          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  slots         ProposedMatchSlot[]
  confirmations MatchParticipantConfirmation[]

  @@index([schedulingStatus])
  @@index([confirmationDeadline])
  @@index([windowEnd])
  @@map("match_schedules")
}

// ─── PROPOSED SLOTS (engine output, ranked) ───────────────────

model ProposedMatchSlot {
  id                 String          @id @default(cuid())
  matchScheduleId    String
  startDateTime      DateTime
  endDateTime        DateTime
  score              Float           @default(0)
  rank               Int             @default(0)
  eligibility        SlotEligibility @default(ELIGIBLE)
  requiresSubstitute Boolean         @default(false)
  isPrimary          Boolean         @default(false)
  isBackup           Boolean         @default(false)
  scoringExplanation String?         @db.Text
  conflictDetails    Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  matchSchedule MatchSchedule @relation(fields: [matchScheduleId], references: [id], onDelete: Cascade)

  @@index([matchScheduleId])
  @@index([matchScheduleId, rank])
  @@map("proposed_match_slots")
}

// ─── PARTICIPANT CONFIRMATIONS (per player per match) ─────────

model MatchParticipantConfirmation {
  id              String             @id @default(cuid())
  matchScheduleId String
  playerId        String
  teamId          String?
  proposedSlotId  String?
  status          ConfirmationStatus @default(PENDING)
  responseReason  String? // maps to reject categories: DUTY_CHANGED, EMERGENCY, ...
  responseNote    String?
  respondedAt     DateTime?
  confirmedById   String? // captain/admin id when confirmed on behalf
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  matchSchedule MatchSchedule @relation(fields: [matchScheduleId], references: [id], onDelete: Cascade)
  player        Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team          Team?         @relation(fields: [teamId], references: [id])

  @@unique([matchScheduleId, playerId])
  @@index([matchScheduleId])
  @@index([playerId])
  @@map("match_participant_confirmations")
}

// ─── RESCHEDULE REQUESTS ──────────────────────────────────────

model RescheduleRequest {
  id               String           @id @default(cuid())
  matchId          String
  requestedById    String // player id
  requestingTeamId String?
  reasonCategory   RescheduleReason
  reasonText       String           @db.Text
  requestedStart   DateTime?
  requestedEnd     DateTime?
  status           RescheduleStatus @default(PENDING)
  opponentResponse String?
  adminDecision    String?
  adminNote        String?
  decidedById      String?
  decidedAt        DateTime?
  isEmergency      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([status])
  @@map("reschedule_requests")
}

// ─── SUBSTITUTE REGISTRATION (per tournament per team) ────────

model SubstituteRegistration {
  id              String              @id @default(cuid())
  tournamentId    String
  teamId          String
  playerId        String
  status          SubstituteRegStatus @default(PENDING)
  registeredAt    DateTime            @default(now())
  approvedById    String?
  eligibilityData Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId, playerId])
  @@index([tournamentId])
  @@index([teamId])
  @@map("substitute_registrations")
}

// ─── SUBSTITUTE ACTIVATION (per match) ────────────────────────

model SubstituteActivation {
  id                 String                     @id @default(cuid())
  matchId            String
  teamId             String
  originalPlayerId   String
  substitutePlayerId String
  requestedById      String
  status             SubstituteActivationStatus @default(REQUESTED)
  approvedById       String?
  reason             String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([teamId])
  @@map("substitute_activations")
}

// ─── MATCH CHECK-IN ───────────────────────────────────────────

model MatchCheckIn {
  id          String        @id @default(cuid())
  matchId     String
  playerId    String
  status      CheckInStatus @default(NOT_CHECKED_IN)
  checkedInAt DateTime?
  source      CheckInSource @default(PLAYER)
  adminNote   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@map("match_check_ins")
}

// ─── SCHEDULING AUDIT LOG ─────────────────────────────────────
// Separate from ActivityLog: captures player + system actions too, with
// before/after snapshots. actorId/matchId/playerId are plain ids (may
// reference either an AdminUser or a Player) so no FK ambiguity.

model SchedulingAuditEvent {
  id           String              @id @default(cuid())
  tournamentId String?
  matchId      String?
  playerId     String?
  actorType    SchedulingActorType @default(SYSTEM)
  actorId      String?
  eventType    String
  previousData Json?
  newData      Json?
  reason       String?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([tournamentId])
  @@index([matchId])
  @@index([playerId])
  @@index([eventType])
  @@index([createdAt])
  @@map("scheduling_audit_events")
}
