generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum GameCategory {
  FOOTBALL
  EFOOTBALL
  PUBG
  SNOOKER
  CHECKERS
}

enum TournamentFormat {
  LEAGUE
  KNOCKOUT
  GROUP_KNOCKOUT
}

enum ParticipantType {
  TEAM
  INDIVIDUAL
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ScoreReportStatus {
  PENDING
  CONFIRMED
  DISPUTED
  AUTO_CONFIRMED
  CANCELLED
}

enum MatchEventType {
  // Football & eFootball
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISS
  CLEAN_SHEET
  MOTM
  // PUBG
  KILL
  // Snooker / Checkers / Generic
  FRAME_WIN
  MVP
  CUSTOM
}

enum AwardType {
  GOLDEN_BOOT
  TOP_ASSISTS
  BEST_PLAYER
  BEST_GOALKEEPER
  FAIR_PLAY
  TOURNAMENT_MVP
  TOURNAMENT_WINNER
  CUSTOM
}

enum ParticipantResult {
  WIN
  LOSS
  DRAW
  DNF
}

// ─────────────────────────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────────────────────────

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      AdminRole @default(EDITOR)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  activityLogs ActivityLog[]

  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────
// SEASON
// ─────────────────────────────────────────────────────────────

model Season {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())

  tournaments Tournament[]

  @@map("seasons")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT
// ─────────────────────────────────────────────────────────────

model Tournament {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String?          @db.Text
  bannerUrl       String?
  logoUrl         String?
  gameCategory    GameCategory
  format          TournamentFormat
  participantType ParticipantType  @default(TEAM)
  status          TournamentStatus @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  seasonId        String?
  maxParticipants Int?
  rules           String?          @db.Text
  prizeInfo       String?
  isFeatured      Boolean          @default(false)
  // eFootball-specific
  eFootballMode   String?          // "1v1" or "2v2" (only for EFOOTBALL)
  eFootballType   String?          // "AUTHENTIC" or "DREAM" (only for EFOOTBALL)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  season    Season?            @relation(fields: [seasonId], references: [id])
  teams     TournamentTeam[]
  players   TournamentPlayer[]
  groups    TournamentGroup[]
  matches   Match[]
  standings Standing[]
  awards    Award[]

  @@index([gameCategory])
  @@index([status])
  @@map("tournaments")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT GROUP
// ─────────────────────────────────────────────────────────────

model TournamentGroup {
  id           String   @id @default(cuid())
  tournamentId String
  name         String
  orderIndex   Int      @default(0)

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams      TournamentTeam[]
  players    TournamentPlayer[]
  matches    Match[]
  standings  Standing[]

  @@unique([tournamentId, name])
  @@map("tournament_groups")
}

// ─────────────────────────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────────────────────────

model Team {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  shortName    String?
  logoUrl      String?
  primaryColor String?
  captainId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  captain      Player?           @relation("TeamCaptain", fields: [captainId], references: [id])
  players      TeamPlayer[]
  tournaments  TournamentTeam[]
  homeMatches  Match[]           @relation("HomeTeam")
  awayMatches  Match[]           @relation("AwayTeam")
  matchEvents  MatchEvent[]
  participants MatchParticipant[]
  awards       Award[]
  standings    Standing[]

  @@index([isActive])
  @@map("teams")
}

// ─────────────────────────────────────────────────────────────
// PLAYER
// ─────────────────────────────────────────────────────────────

model Player {
  id          String    @id @default(cuid())
  name        String
  nickname    String?
  slug        String    @unique
  photoUrl    String?
  dateOfBirth DateTime?
  nationality String?
  phone       String?   // WhatsApp number with country code e.g. +923001234567
  position    String?
  skillLevel  Int?      @default(50) // 0-99 rating for seeding
  eloRating   Int       @default(100)
  bio              String?   @db.Text
  isActive         Boolean   @default(true)
  registrationStatus String  @default("APPROVED") // PENDING, APPROVED, REJECTED
  suspendedUntil   DateTime?
  suspensionReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  teams           TeamPlayer[]
  tournaments     TournamentPlayer[]
  matchEvents     MatchEvent[]
  participants    MatchParticipant[]
  captainOf       Team[]             @relation("TeamCaptain")
  awards          Award[]
  manOfTheMatches Match[]            @relation("MatchMOTM")
  homeMatches     Match[]            @relation("HomePlayer")
  awayMatches     Match[]            @relation("AwayPlayer")
  standings       Standing[]
  eloHistory      EloHistory[]
  eloAsOpponent   EloHistory[]       @relation("EloOpponent")
  availabilities  MatchAvailability[]

  @@index([isActive])
  @@map("players")
}

// ─────────────────────────────────────────────────────────────
// TEAM ↔ PLAYER (roster + transfer history)
// ─────────────────────────────────────────────────────────────

model TeamPlayer {
  id           String    @id @default(cuid())
  teamId       String
  playerId     String
  jerseyNumber Int?
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?
  isActive     Boolean   @default(true)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId, joinedAt])
  @@index([teamId])
  @@index([playerId])
  @@map("team_players")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT TEAMS (enrollment)
// ─────────────────────────────────────────────────────────────

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  groupId      String?
  seedNumber   Int?
  registeredAt DateTime @default(now())

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team              @relation(fields: [teamId], references: [id])
  group      TournamentGroup?  @relation(fields: [groupId], references: [id])

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@map("tournament_teams")
}

// ─────────────────────────────────────────────────────────────
// TOURNAMENT PLAYERS (individual enrollment)
// ─────────────────────────────────────────────────────────────

model TournamentPlayer {
  id           String   @id @default(cuid())
  tournamentId String
  playerId     String
  teamId       String?
  groupId      String?
  registeredAt DateTime @default(now())

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player            @relation(fields: [playerId], references: [id])
  group      TournamentGroup?  @relation(fields: [groupId], references: [id])

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([groupId])
  @@map("tournament_players")
}

// ─────────────────────────────────────────────────────────────
// VENUE
// ─────────────────────────────────────────────────────────────

model Venue {
  id      String  @id @default(cuid())
  name    String
  address String?
  city    String?

  matches Match[]

  @@map("venues")
}

// ─────────────────────────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────────────────────────

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  groupId      String?
  venueId      String?

  // Round info
  round        String?
  roundNumber  Int?
  matchNumber  Int?

  // Team vs team
  homeTeamId    String?
  awayTeamId    String?

  // Player vs player (e.g. eFootball 1v1)
  homePlayerId  String?
  awayPlayerId  String?

  // Leg 1 scores (or single match score)
  homeScore     Int?
  awayScore     Int?
  homeScorePens Int?
  awayScorePens Int?

  // Leg 2 scores (knockout 2-legged ties)
  leg2HomeScore Int?
  leg2AwayScore Int?

  // Leg 3 / Decider (if aggregate tied after 2 legs)
  leg3HomeScore Int?
  leg3AwayScore Int?
  leg3HomePens  Int?
  leg3AwayPens  Int?

  // In-game clubs (eFootball)
  homeClub String?
  awayClub String?

  // Formation & tactics (eFootball)
  homeFormation String?
  awayFormation String?

  // Derby / rivalry
  isDerby   Boolean @default(false)
  rivalNote String?

  // Man of the match
  motmPlayerId String?

  // Knockout bracket progression
  nextMatchId       String?
  nextMatchPosition String? // "home" or "away"

  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  highlights  String?     @db.Text

  // Deadline & reminder system
  deadline      DateTime?
  remindersSent Json      @default("[]")
  isOverdue     Boolean   @default(false)

  // Room ID for online matches (eFootball, PUBG)
  roomId        String?
  roomPassword  String?

  // Score self-reporting magic link tokens
  homeToken     String?   @unique
  awayToken     String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group           TournamentGroup?  @relation(fields: [groupId], references: [id])
  venue           Venue?            @relation(fields: [venueId], references: [id])
  homeTeam        Team?             @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team?             @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homePlayer      Player?           @relation("HomePlayer", fields: [homePlayerId], references: [id])
  awayPlayer      Player?           @relation("AwayPlayer", fields: [awayPlayerId], references: [id])
  motmPlayer      Player?           @relation("MatchMOTM", fields: [motmPlayerId], references: [id])
  events          MatchEvent[]
  participants    MatchParticipant[]
  nextMatch       Match?            @relation("KnockoutProgression", fields: [nextMatchId], references: [id])
  previousMatches Match[]           @relation("KnockoutProgression")
  eloHistory      EloHistory[]
  scoreReports    ScoreReport[]
  availabilities  MatchAvailability[]

  @@index([tournamentId])
  @@index([status])
  @@index([status, deadline])
  @@index([homePlayerId])
  @@index([awayPlayerId])
  @@map("matches")
}

// ─────────────────────────────────────────────────────────────
// ELO HISTORY
// ─────────────────────────────────────────────────────────────

model EloHistory {
  id                   String   @id @default(cuid())
  playerId             String
  matchId              String
  ratingBefore         Int
  ratingAfter          Int
  change               Int
  opponentId           String
  opponentRatingBefore Int
  result               String   // WIN, LOSS, DRAW
  kFactor              Int
  createdAt            DateTime @default(now())

  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  opponent Player @relation("EloOpponent", fields: [opponentId], references: [id])

  @@index([playerId])
  @@index([matchId])
  @@index([playerId, createdAt])
  @@map("elo_history")
}

// ─────────────────────────────────────────────────────────────
// MATCH PARTICIPANT (multi-team/PUBG battle royale)
// ─────────────────────────────────────────────────────────────

model MatchParticipant {
  id        String             @id @default(cuid())
  matchId   String
  teamId    String?
  playerId  String?
  placement Int?
  score     Float?
  result    ParticipantResult?
  notes     String?

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])

  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@map("match_participants")
}

// ─────────────────────────────────────────────────────────────
// MATCH EVENT (atomic stat record — source of truth)
// ─────────────────────────────────────────────────────────────

model MatchEvent {
  id          String         @id @default(cuid())
  matchId     String
  playerId    String?
  teamId      String?
  type        MatchEventType
  minute      Int?
  value       Float?
  description String?
  createdAt   DateTime       @default(now())

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id])
  team   Team?   @relation(fields: [teamId], references: [id])

  @@index([matchId])
  @@index([playerId])
  @@index([type])
  @@map("match_events")
}

// ─────────────────────────────────────────────────────────────
// STANDING (points table — recomputed after every result)
// ─────────────────────────────────────────────────────────────

model Standing {
  id           String  @id @default(cuid())
  tournamentId String
  groupId      String?
  teamId       String?
  playerId     String?

  played Int   @default(0)
  won    Int   @default(0)
  drawn  Int   @default(0)
  lost   Int   @default(0)
  points Int   @default(0)

  // Football / eFootball
  goalsFor     Int @default(0)
  goalsAgainst Int @default(0)
  goalDiff     Int @default(0)
  cleanSheets  Int @default(0)

  // Generic (PUBG score, snooker frames, etc.)
  totalScore Float @default(0)

  updatedAt DateTime @updatedAt

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group      TournamentGroup?  @relation(fields: [groupId], references: [id])
  team       Team?             @relation(fields: [teamId], references: [id])
  player     Player?           @relation(fields: [playerId], references: [id])

  @@index([tournamentId])
  @@index([tournamentId, playerId])
  @@index([tournamentId, teamId])
  @@map("standings")
}

// ─────────────────────────────────────────────────────────────
// AWARD
// ─────────────────────────────────────────────────────────────

model Award {
  id           String    @id @default(cuid())
  tournamentId String
  type         AwardType
  customName   String?
  playerId     String?
  teamId       String?
  description  String?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player?    @relation(fields: [playerId], references: [id])
  team       Team?      @relation(fields: [teamId], references: [id])

  @@index([tournamentId])
  @@index([tournamentId, type])
  @@map("awards")
}

// ─────────────────────────────────────────────────────────────
// NEWS POST
// ─────────────────────────────────────────────────────────────

model NewsPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  coverUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("news_posts")
}

// ─────────────────────────────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────
// PUSH SUBSCRIPTIONS (Web Push API)
// ─────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model FcmToken {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())

  @@map("fcm_tokens")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION LOG (central record of all sent notifications)
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  url       String?
  tag       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// APP SETTINGS (single-row global config)
// ─────────────────────────────────────────────────────────────

model AppSettings {
  id        String   @id @default("global")

  // Global kill switch
  testMode  Boolean  @default(false)

  // Push notification toggles (Web Push + FCM)
  pushMatchReminders         Boolean @default(true)
  pushScoreSubmissions       Boolean @default(true)
  pushMatchResults           Boolean @default(true)
  pushTournamentUpdates      Boolean @default(true)
  pushRoomId                 Boolean @default(true)
  pushAdminAlerts            Boolean @default(true)

  // WhatsApp notification toggles
  waMatchReminders           Boolean @default(true)
  waScoreSubmissions         Boolean @default(true)
  waMatchResults             Boolean @default(true)
  waTournamentUpdates        Boolean @default(true)
  waRoomId                   Boolean @default(true)
  waAdminAlerts              Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────────────────────────────────
// MATCH AVAILABILITY (player readiness tracking)
// ─────────────────────────────────────────────────────────────

model MatchAvailability {
  id            String    @id @default(cuid())
  matchId       String
  playerId      String
  side          String    // "home" or "away"
  isAvailable   Boolean   @default(true)
  preferredTime DateTime?
  markedAt      DateTime  @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, side])
  @@index([matchId])
  @@map("match_availabilities")
}

// ─────────────────────────────────────────────────────────────
// SCORE SELF-REPORTING
// ─────────────────────────────────────────────────────────────

model ScoreReport {
  id            String            @id @default(cuid())
  matchId       String
  submittedBy   String            // "home" or "away"
  homeScore     Int
  awayScore     Int
  status        ScoreReportStatus @default(PENDING)
  submittedAt   DateTime          @default(now())
  respondedAt   DateTime?
  autoConfirmAt DateTime
  disputeReason String?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([status, autoConfirmAt])
  @@map("score_reports")
}
